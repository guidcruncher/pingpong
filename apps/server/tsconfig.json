{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "sourceMap": true,
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
     "@/*": [
        "./src/*"
       ]
     }
  },
  "include": ["./src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}

