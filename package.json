{
  "name": "pingpong",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "format": "prettier --no-error-on-unmatched-pattern --ignore-unknown --config ./.prettierrc --write \"./apps/server/src/**/*.ts\"  \"./shared/src/**/*.ts\"  \"./apps/client/src/**/*.ts\"  \"./apps/client/src/**/*.vue\" ",
    "db:migrate": "docker compose -f ./docker-compose.dbmigrate.yml up",
    "db": "sqlite3 ../run/data/network-inventory.db",
    "docker:build": "docker compose -f ./docker-compose.dev.yml build --no-cache",
    "docker:up": "docker compose -f ./docker-compose.dev.yml build --no-cache && docker compose -f ./docker-compose.dev.yml up",
    "docker:rm ": "&& docker compose -f ./docker-compose.dev.yml rm -f",
    "docker:debug": "docker run --rm -it --entrypoint /bin/bash guidcruncher/pingpong:latest",
    "docker:sh": "docker exec -it pingpong bash",
    "scan": "curl -v \"http://127.0.0.1:5173/api/scanner\"",
    "lint": "eslint ./apps/server/src/ && eslint ./apps/client/src && eslint ./shared/src",
    "lint:fix": "eslint ./shared/src/ --fix && eslint ./apps/server/src --fix && eslint ./apps/client/src --fix",
    "build": "rm -rf ./dist && pnpm -r build",
    "dev": "pnpm -r dev"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "@types/node": "^25.0.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "eslint": "^10.2.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "@eslint/js": "^10.0.1"
  }
}
